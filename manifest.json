{
  "manifest_version": 3,
  "version": "1.3.1",
  "name": "YouTube Grid Lab",
  "description": "YouTubeの1行あたりの動画数・ショート数・チャンネルページのレイアウトをカスタマイズします。配色テーマも選べます。",
  "permissions": [
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.youtube.com/*"
  ],
  "background": {
    "scripts": [
      "background.js"
    ]
  },
  "action": {
    "default_title": "YouTube Grid Lab",
    "default_icon": "images/gridLab-32.png",
    "default_popup": "popup.html"
  },
  "icons": {
    "16": "images/gridLab-16.png",
    "32": "images/gridLab-32.png",
    "48": "images/gridLab-48.png",
    "64": "images/gridLab-64.png",
    "128": "images/gridLab-128.png"
  },
  "content_scripts": [
    {
      "run_at": "document_start",
      "matches": [
        "https://www.youtube.com/*"
      ],
      "js": [
        "storage-key.js",
        "storage.js",
        "content_script.js"
      ]
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "youtube-grid-lab-fx@example.invalid",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
